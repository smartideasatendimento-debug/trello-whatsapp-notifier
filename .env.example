# ============================================
# TRELLO CONFIGURATION
# ============================================
# Obtenha sua API Key em: https://trello.com/power-ups/admin
TRELLO_API_KEY=sua_api_key_aqui

# Gere seu Token em: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=SUA_API_KEY
TRELLO_TOKEN=seu_token_aqui

# ID do quadro Trello (extra횄짯do da URL do quadro)
TRELLO_BOARD_ID=h4XEGbpc

# ============================================
# Z-API CONFIGURATION (WhatsApp)
# ============================================
# Obtenha em: https://www.z-api.io/ 창혛혪 Painel 창혛혪 Sua inst횄짖ncia
ZAPI_INSTANCE_ID=sua_instance_id
ZAPI_TOKEN=seu_token_zapi
ZAPI_CLIENT_TOKEN=seu_client_token

# ============================================
# VERCEL KV (Redis) - Configura횄짠횄짙o autom횄징tica no Vercel
# ============================================
# KV_REST_API_URL=auto_configurado_pelo_vercel
# KV_REST_API_TOKEN=auto_configurado_pelo_vercel

# ============================================
# SEGURAN횄혝A
# ============================================
# Chave secreta para proteger os endpoints de cron
CRON_SECRET=gere_uma_chave_secreta_aleatoria

# URL base da aplica횄짠횄짙o (para configurar webhooks do Trello)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app
